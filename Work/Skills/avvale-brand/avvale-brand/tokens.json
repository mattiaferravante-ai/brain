{
  "$schema": "design-tokens",
  "brand": {
    "name": "Avvale",
    "parent_group": "Techedge",
    "voice": ["concreto", "competente", "diretto", "affidabile", "misurabile"]
  },
  "color": {
    "primary": {
      "pure_white":    {"hex": "#FFFFFF", "rgb": [255,255,255], "cmyk": [0,0,0,0],     "role": "background, text-on-dark"},
      "raisin_black":  {"hex": "#231C1D", "rgb": [35,28,29],    "cmyk": [70,69,59,80], "role": "body text, dark backgrounds"},
      "celadon_green": {"hex": "#248B7E", "rgb": [36,139,126],  "cmyk": [80,23,54,7],  "role": "signature accent (titles, KPI, primary series)", "signature": true},
      "keppel":        {"hex": "#47B1A3", "rgb": [71,177,163],  "cmyk": [69,5,43,0],   "role": "secondary accent"},
      "green_ryb":     {"hex": "#5AB031", "rgb": [90,176,49],   "cmyk": [68,0,100,0],  "role": "growth/positive accent"},
      "pistachio":     {"hex": "#AACE7C", "rgb": [170,206,124], "cmyk": [41,0,64,0],   "role": "soft backgrounds, callout"}
    },
    "secondary": {
      "acqua_blue":     {"hex": "#989FCE", "rgb": [152,159,206]},
      "almond":         {"hex": "#FFECD1", "rgb": [255,236,209]},
      "lilac_luster":   {"hex": "#B79FAD", "rgb": [183,159,173]},
      "english_violet": {"hex": "#574B60", "rgb": [87,75,98]},
      "red_salsa":      {"hex": "#EB5758", "rgb": [235,87,88]},
      "bittersweet":    {"hex": "#412647", "rgb": [65,38,71]},
      "champagne_pink": {"hex": "#EADDD6", "rgb": [234,221,214]}
    },
    "neutral": {
      "grid_line":     {"hex": "#E5E5E5"},
      "alt_row":       {"hex": "#F5F5F5"},
      "muted_text":    {"hex": "#6E6566", "note": "Raisin Black ~60% opacity baked"}
    },
    "chart_series_order": [
      "#248B7E",
      "#231C1D",
      "#47B1A3",
      "#AACE7C",
      "#989FCE",
      "#574B60",
      "#5AB031"
    ],
    "rules": {
      "max_primary_in_one_doc": 3,
      "must_include": ["#248B7E"],
      "forbidden": ["Office default theme blues/oranges", "tricolor red-yellow-green"]
    }
  },
  "typography": {
    "primary_family": "Archivo",
    "primary_family_url": "https://fonts.google.com/specimen/Archivo",
    "weights_allowed": ["Thin", "Regular", "Bold", "Extrabold"],
    "italics_allowed": true,
    "fallback_chain": ["Inter", "Helvetica", "Arial"],
    "scale": {
      "cover_title":   {"weight": "Extrabold", "size_pt": [48, 60]},
      "section_title": {"weight": "Extrabold", "size_pt": [40, 48]},
      "h1":            {"weight": "Bold",      "size_pt": [24, 28]},
      "h2":            {"weight": "Bold",      "size_pt": [16, 20]},
      "h3":            {"weight": "Bold",      "size_pt": [13, 14]},
      "body":          {"weight": "Regular",   "size_pt": [14, 18], "doc_body_pt": [11, 12]},
      "caption":       {"weight": "Regular",   "size_pt": [9, 11],  "italic": true},
      "kpi_value":     {"weight": "Extrabold", "size_pt": [44, 60]},
      "kpi_label":     {"weight": "Regular",   "size_pt": [11, 13]},
      "footer":        {"weight": "Regular",   "size_pt": [8, 10]}
    },
    "alignment": {
      "body": "left",
      "no_full_justify": true,
      "centered_only_for": ["cover", "section_divider", "closing"]
    }
  },
  "logo": {
    "primary_orientation": "horizontal",
    "stacked_when": "horizontal logo doesn't fit",
    "paths": {
      "horizontal_positive":   "assets/logo/logo_pos.png",
      "horizontal_negative":   "assets/logo/logo_neg.png",
      "horizontal_positive_payoff": "assets/logo/logo_pos_payoff.png",
      "horizontal_negative_payoff": "assets/logo/logo_neg_payoff.png",
      "stacked_positive":      "assets/logo/logo_pos_portrait.png",
      "stacked_negative":      "assets/logo/logo_neg_portrait.png"
    },
    "default_for_light_bg": "horizontal_positive",
    "default_for_dark_bg":  "horizontal_negative",
    "min_size": {
      "horizontal": {"print_mm": 20, "digital_px": 55},
      "stacked":    {"print_mm": 15, "digital_px": 42}
    },
    "clearspace": {
      "horizontal": "X (mark height)",
      "stacked":    "0.75 X"
    },
    "donts": [
      "stretch / skew / rotate the logo (orientation logos)",
      "change colors of the logo",
      "add outline, glow, shadow, gradient",
      "place over low-contrast background",
      "use logotype 'avvale' alone without the mark",
      "recreate logotype with another typeface"
    ]
  },
  "graphic_elements": {
    "pictogram_black": "assets/graphic-elements/pictogram_black.png",
    "pictogram_white": "assets/graphic-elements/pictogram_white.png",
    "symbol_arrow":    "assets/graphic-elements/symbol_arrow.png",
    "symbol_quote":    "assets/graphic-elements/symbol_quote.png",
    "bg_pattern_black":"assets/graphic-elements/bg_pattern_black.png",
    "bg_pattern_white":"assets/graphic-elements/bg_pattern_white.png",
    "bg_pattern_pink": "assets/graphic-elements/bg_pattern_pink.png",
    "pattern_rotation_deg": -28,
    "mark_as_decoration": "allowed (the cross can extend beyond margins, as long as center + 4 arms remain visible)"
  },
  "spacing": {
    "page_margins": {
      "pptx_in":   {"all": 0.5, "safe_in": 0.7},
      "docx_cm":   {"all": 2.5},
      "pdf_mm":    {"all": 20}
    },
    "grid_columns_pptx": 12,
    "line_height": 1.4
  },
  "tone_of_voice": {
    "do": [
      "Be concrete and outcome-oriented",
      "Use measurable claims (numbers, deadlines, percentages)",
      "Use active verbs, short sentences",
      "Use precise tech terms when they add clarity",
      "Italian: formal register, 'voi/lei' for client, 'noi' for Avvale",
      "English: neutral business English"
    ],
    "dont": [
      "Use buzzwords like 'revolutionary', 'best-in-class', 'rivoluzionario', 'game-changing'",
      "Use emoji in formal materials",
      "Hide ideas behind jargon",
      "Use stock cliché imagery (handshakes, lightbulbs)",
      "Use marketing-speak instead of plain claims"
    ]
  },
  "file_naming": {
    "pattern": "avvale_<doc-type>_<subject>_<YYYYMMDD>.<ext>",
    "examples": [
      "avvale_proposal_acme-data-platform_20260429.pptx",
      "avvale_executive-summary_retail-data_20260429.docx"
    ]
  }
}
